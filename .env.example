# === Neon Postgres(同一连接串,双 driver: HTTP for Drizzle, WebSocket for LangGraph PostgresSaver)===
NEON_DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
NEON_DATABASE_URL_WS=postgresql://user:pass@host/db?sslmode=require

# === Upstash Redis(2024-12 后 Vercel KV 替代;限流 + manual override + HITL auto-approve)===
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# === Vercel AI Gateway(所有 LLM + embedding 调用)===
AI_GATEWAY_API_KEY=xxx

# === 可选 ===
DEMO_TEAM_CODE=                   # 留空=匿名公开;设值=要求 ?team_code= 校验
SENTRY_DSN=                       # 可选,空则 console.error
